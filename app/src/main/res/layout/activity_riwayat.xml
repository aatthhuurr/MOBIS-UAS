<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://tools.android.com/tools"
    android:id="@+id/layoutMainRiwayat"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA"
    tools:context=".RiwayatActivity">

    <!-- HEADER / TOOLBAR -->
    <LinearLayout
        android:id="@+id/layoutHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:elevation="2dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="Kembali"
            android:src="@android:drawable/ic_menu_revert"
            app:tint="@color/blue_atma_luhur" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="Riwayat Laporan Saya"
            android:textColor="@color/blue_atma_luhur"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- AREA SEARCH & FILTER (Berdampingan Sesuai Desain Tim) -->
    <LinearLayout
        android:id="@+id/layoutSearchArea"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingTop="16dp"
        android:gravity="center_vertical"
        app:layout_constraintTop_toBottomOf="@+id/layoutHeader">

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/layoutSearch"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Cari Laporan..."
            app:startIconDrawable="@android:drawable/ic_menu_search"
            app:boxStrokeColor="@color/blue_atma_luhur"
            app:hintTextColor="@color/blue_atma_luhur">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/edtSearch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnFilter"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="FILTER"
            android:textColor="@color/blue_atma_luhur"
            app:strokeColor="@color/blue_atma_luhur"
            app:icon="@android:drawable/ic_menu_manage"
            app:iconTint="@color/blue_atma_luhur" />
    </LinearLayout>

    <!-- LIST DAFTAR RECYCLERVIEW -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvRiwayat"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:clipToPadding="false"
        tools:listitem="@layout/item_riwayat"
        app:layout_constraintTop_toBottomOf="@+id/layoutSearchArea"
        app:layout_constraintBottom_toBottomOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>