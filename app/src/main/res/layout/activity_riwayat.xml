<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://tools.android.com/tools"
    android:id="@+id/layoutMainRiwayat"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app"
    tools:context=".RiwayatActivity">

    <!-- HEADER / TOOLBAR -->
    <LinearLayout
        android:id="@+id/layoutHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:elevation="2dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_back_button"
            android:contentDescription="Kembali"
            android:padding="10dp"
            android:src="@drawable/ic_arrow_back"
            app:tint="@color/blue_atma_luhur" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="Riwayat Laporan Saya"
            android:textColor="@color/blue_atma_luhur"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- GARIS PEMBATAS BATIK CUAL (Sentuhan Magis Kedaerahan Babel) -->
    <ImageView
        android:id="@+id/imgPembatasBatik"
        android:layout_width="match_parent"
        android:layout_height="6dp"
        android:scaleType="centerCrop"
        android:src="@drawable/batik"
        android:contentDescription="Garis Pembatas Batik Cual"
        app:layout_constraintTop_toBottomOf="@+id/layoutHeader"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- AREA SEARCH & FILTER (Diselaraskan dengan Radius 20dp & Warna Solid) -->
    <LinearLayout
        android:id="@+id/layoutSearchArea"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingTop="16dp"
        android:gravity="center_vertical"
        app:layout_constraintTop_toBottomOf="@+id/imgPembatasBatik">

        <!-- Input Cari Laporan (Rounded 20dp) -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/layoutSearch"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Cari Laporan..."
            app:startIconDrawable="@android:drawable/ic_menu_search"
            app:startIconTint="@color/blue_atma_luhur"
            app:boxBackgroundColor="@android:color/white"
            app:boxCornerRadiusTopStart="20dp"
            app:boxCornerRadiusTopEnd="20dp"
            app:boxCornerRadiusBottomStart="20dp"
            app:boxCornerRadiusBottomEnd="20dp"
            app:boxStrokeColor="@color/blue_atma_luhur"
            app:hintTextColor="@color/blue_atma_luhur"
            app:boxStrokeWidthFocused="2dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/edtSearch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"
                android:paddingTop="14dp"
                android:paddingBottom="14dp"
                android:textColor="@color/blue_atma_luhur" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Tombol Filter (Berubah menjadi Solid Berwarna Premium) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnFilter"
            android:layout_width="wrap_content"
            android:layout_height="54dp"
            android:layout_marginStart="12dp"
            android:text="FILTER"
            android:textColor="@color/white"
            android:textStyle="bold"
            app:backgroundTint="@color/blue_atma_luhur"
            app:icon="@android:drawable/ic_menu_manage"
            app:iconTint="@color/white"
            app:cornerRadius="20dp"
            android:elevation="4dp" />
    </LinearLayout>

    <!-- LIST DAFTAR RECYCLERVIEW (Ditambahkan Padding Bawah agar tidak menabrak FAB) -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvRiwayat"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:clipToPadding="false"
        android:paddingBottom="92dp"
        tools:listitem="@layout/item_riwayat"
        app:layout_constraintTop_toBottomOf="@+id/layoutSearchArea"
        app:layout_constraintBottom_toBottomOf="parent"/>

    <!-- TOMBOL TAMBAH MELAYANG (+) -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabTambahLaporan"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="24dp"
        android:contentDescription="Tambah Laporan Baru"
        android:src="@android:drawable/ic_input_add"
        app:backgroundTint="@color/blue_atma_luhur"
        app:tint="@color/white"
        app:fabSize="normal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:elevation="6dp" />

</androidx.constraintlayout.widget.ConstraintLayout>