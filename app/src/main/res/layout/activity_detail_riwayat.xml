<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://tools.android.com/tools"
    android:id="@+id/layoutMainDetailRiwayat"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app"
    tools:context=".DetailRiwayatActivity">

    <!-- 1. BAGIAN HEADER TOOLBAR DETAIL -->
    <LinearLayout
        android:id="@+id/layoutHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:elevation="2dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        android:paddingVertical="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_back_button"
            android:contentDescription="Kembali"
            android:padding="10dp"
            android:src="@android:drawable/ic_menu_revert"
            app:tint="@color/blue_atma_luhur" />

        <TextView
            android:id="@+id/txtToolbarTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="Detail Laporan"
            android:textColor="@color/blue_atma_luhur"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- KREASI KEDAERAHAN: GARIS PEMBATAS BATIK CUAL (Konsisten dengan Halaman Riwayat) -->
    <ImageView
        android:id="@+id/imgPembatasBatikDetail"
        android:layout_width="match_parent"
        android:layout_height="6dp"
        android:scaleType="centerCrop"
        android:src="@drawable/batik"
        android:contentDescription="Garis Pembatas Batik Cual"
        app:layout_constraintTop_toBottomOf="@+id/layoutHeader"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- AREA SCROLL CONTENT DETAIL -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@+id/imgPembatasBatikDetail"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- 2. KARTU DETAIL INFORMASI UTAMA (Rounded 20dp) -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Judul Laporan"
                        android:textColor="#6C757D"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/txtDetailJudul"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Polusi Air Sungai"
                        android:textColor="@color/blue_atma_luhur"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_marginTop="2dp"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#E9ECEF"
                        android:layout_marginVertical="12dp"/>

                    <TextView
                        android:id="@+id/txtDetailKategori"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Kategori: Gangguan Lingkungan"
                        android:textColor="#495057"
                        android:textSize="14sp" />

                    <!-- 3. BADGE STATUS LAPORAN (Melengkung Rapi & Berjarak Luas) -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        app:cardBackgroundColor="#FFF3CD"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="0dp">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="6dp">

                            <ImageView
                                android:id="@+id/imgDetailStatusIcon"
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:src="@android:drawable/stat_sys_warning"
                                app:tint="#856404" />

                            <TextView
                                android:id="@+id/txtDetailStatus"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="6dp"
                                android:text="MENUNGGU TANGGAPAN"
                                android:textColor="#856404"
                                android:textSize="12sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <TextView
                        android:id="@+id/txtDetailTanggal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:text="Dilapor: 15 Juni 2026, 09:00:00 WIB"
                        android:textColor="#6C757D"
                        android:textSize="12sp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- LABEL KRONOLOGIS -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="KRONOLOGIS KEJADIAN"
                android:textColor="@color/blue_atma_luhur"
                android:textSize="12sp"
                android:textStyle="bold" />

            <!-- 4. KARTU DESKRIPSI KRONOLOGIS (Rounded 16dp) -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="@color/white">

                <TextView
                    android:id="@+id/txtDetailKronologis"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:text="Polusi air sungai di Jl. Sudirman kategori penampungan lokasi membawa dampak buruk bagi warga sekitar. Mohon tim sekalian meninjau lokasi..."
                    android:textColor="#495057"
                    android:textSize="14sp"
                    android:lineSpacingMultiplier="1.2"/>
            </androidx.cardview.widget.CardView>

            <!-- LABEL BUKTI -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="BUKTI DOKUMENTASI"
                android:textColor="@color/blue_atma_luhur"
                android:textSize="12sp"
                android:textStyle="bold" />

            <!-- 5. AREA BUKTI VISUAL BESAR (Rounded 16dp) -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:layout_marginTop="6dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="@color/white">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <ImageView
                        android:id="@+id/imgDetailBukti"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@drawable/kamera"
                        android:contentDescription="Bukti Visual Laporan"/>

                    <VideoView
                        android:id="@+id/videoDetailBukti"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_gravity="center"
                        android:visibility="gone"/>
                </FrameLayout>
            </androidx.cardview.widget.CardView>

            <!-- LABEL TANGGAPAN -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="TANGGAPAN &amp; PROSES"
                android:textColor="@color/blue_atma_luhur"
                android:textSize="12sp"
                android:textStyle="bold" />

            <!-- 6. TIMELINE TIMBAL BALIK ADMIN (Rounded 16dp) -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Respon Sistem / Admin:"
                        android:textColor="@color/blue_atma_luhur"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/txtDetailTanggapanAdmin"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Terima kasih atas laporannya. Tim kami sudah meninjau lokasi... dilapor\n17 Juni 2026, 09:45:11 WIB"
                        android:textColor="#495057"
                        android:textSize="13sp"
                        android:lineSpacingMultiplier="1.1"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#E9ECEF"
                        android:layout_marginVertical="12dp"/>

                    <TextView
                        android:id="@+id/txtDetailDitanggapi"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ditanggapi pada:\n17 Juni 2026, 14:45:11 WIB"
                        android:textColor="#6C757D"
                        android:textSize="12sp"
                        android:textStyle="italic"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>