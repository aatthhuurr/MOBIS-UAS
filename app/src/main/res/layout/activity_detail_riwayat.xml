<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://tools.android.com/tools"
    android:id="@+id/layoutMainDetailRiwayat"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA"
    tools:context=".DetailRiwayatActivity">

    <!-- 1. HEADER / TOOLBAR -->
    <LinearLayout
        android:id="@+id/layoutHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:elevation="2dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="Kembali"
            android:src="@android:drawable/ic_menu_revert"
            app:tint="@color/blue_atma_luhur" />

        <TextView
            android:id="@+id/txtToolbarTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="Detail Laporan"
            android:textColor="@color/blue_atma_luhur"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- AREA SCROLL DETAIL CONTENT -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@+id/layoutHeader"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- KARTU DETAIL INFORMASI UTAMA -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="8dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Judul Laporan"
                        android:textColor="#6C757D"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/txtDetailJudul"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Polusi Air Sungai"
                        android:textColor="@color/blue_atma_luhur"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_marginTop="2dp"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#E9ECEF"
                        android:layout_marginVertical="12dp"/>

                    <TextView
                        android:id="@+id/txtDetailKategori"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Kategori: Gangguan Lingkungan"
                        android:textColor="#495057"
                        android:textSize="14sp" />

                    <!-- Badge Status Laporan -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="#FFF3CD"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="6dp">

                        <ImageView
                            android:id="@+id/imgDetailStatusIcon"
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@android:drawable/stat_sys_warning"
                            app:tint="#856404" />

                        <TextView
                            android:id="@+id/txtDetailStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="6dp"
                            android:text="MENUNGGU TANGGAPAN"
                            android:textColor="#856404"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/txtDetailTanggal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Dilapor: 15 Juni 2026, 09:00:00 WIB"
                        android:textColor="#6C757D"
                        android:textSize="12sp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- KARTU DESKRIPSI KRONOLOGIS -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="KRONOLOGIS KEJADIAN"
                android:textColor="@color/blue_atma_luhur"
                android:textSize="12sp"
                android:textStyle="bold" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/white">

                <TextView
                    android:id="@+id/txtDetailKronologis"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:text="Polusi air sungai di Jl. Sudirman kategori penampungan lokasi membawa dampak buruk bagi warga sekitar. Mohon tim sekalian meninjau lokasi..."
                    android:textColor="#495057"
                    android:textSize="14sp"
                    android:lineSpacingMultiplier="1.2"/>
            </androidx.cardview.widget.CardView>

            <!-- AREA BUKTI FOTO / VIDEO BESAR -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="BUKTI DOKUMENTASI"
                android:textColor="@color/blue_atma_luhur"
                android:textSize="12sp"
                android:textStyle="bold" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:layout_marginTop="6dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/white">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <ImageView
                        android:id="@+id/imgDetailBukti"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@drawable/kamera"
                        android:contentDescription="Bukti Visual Laporan"/>

                    <VideoView
                        android:id="@+id/videoDetailBukti"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_gravity="center"
                        android:visibility="gone"/>
                </FrameLayout>
            </androidx.cardview.widget.CardView>

            <!-- TIMELINE TIMBAL BALIK ADMIN -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="TANGGAPAN &amp; PROSES"
                android:textColor="@color/blue_atma_luhur"
                android:textSize="12sp"
                android:textStyle="bold" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Respon Sistem / Admin:"
                        android:textColor="@color/blue_atma_luhur"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/txtDetailTanggapanAdmin"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Terima kasih atas laporannya. Tim kami sudah meninjau lokasi... dilapor\n17 Juni 2026, 09:45:11 WIB"
                        android:textColor="#495057"
                        android:textSize="13sp"
                        android:lineSpacingMultiplier="1.1"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#E9ECEF"
                        android:layout_marginVertical="12dp"/>

                    <TextView
                        android:id="@+id/txtDetailDitanggapi"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ditanggapi pada:\n17 Juni 2026, 14:45:11 WIB"
                        android:textColor="#6C757D"
                        android:textSize="12sp"
                        android:textStyle="italic"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>