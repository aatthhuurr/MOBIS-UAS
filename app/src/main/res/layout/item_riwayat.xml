<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://tools.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="top">

        <!-- Kiri: Area Teks Informasi yang WAJIB BERURUTAN dari Soal Dosen -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginEnd="16dp">

            <!-- 1. Judul Pengaduan -->
            <TextView
                android:id="@+id/txtJudulPengaduan"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Polusi Air Sungai"
                android:textColor="@color/blue_atma_luhur"
                android:textSize="16sp"
                android:textStyle="bold" />

            <!-- 3. Status Laporan -->
            <TextView
                android:id="@+id/txtStatusLaporan"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="MENUNGGU TANGGAPAN"
                android:textColor="#C29302"
                android:textSize="12sp"
                android:textStyle="bold" />

            <!-- 4. Kategori Laporan -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Kategori: "
                    android:textColor="#6C757D"
                    android:textSize="13sp"/>

                <TextView
                    android:id="@+id/txtKategoriLaporan"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Gangguan Lingkungan"
                    android:textColor="#495057"
                    android:textSize="13sp" />
            </LinearLayout>

            <!-- 5. Tanggapan Admin (Dibuat melengkung/rounded rapi di dalam kartu) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="vertical"
                android:padding="10dp"
                android:background="#F4F5F7">

                <TextView
                    android:id="@+id/txtTanggapanAdmin"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Tanggapan Admin: (Belum ada tanggapan resmi dari pihak terkait)"
                    android:textColor="#6C757D"
                    android:textSize="12sp"
                    android:textStyle="italic" />
            </LinearLayout>

            <!-- 6. Tanggal Pelaporan -->
            <TextView
                android:id="@+id/txtTanggalPelaporan"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Dilapor: 15 Juni 2026, 09:00:00 WIB"
                android:textColor="#A2AAB2"
                android:textSize="11sp" />

            <!-- 7. Tanggal Ditanggapi -->
            <TextView
                android:id="@+id/txtTanggalDitanggapi"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="Ditanggapi: --"
                android:textColor="#A2AAB2"
                android:textSize="11sp" />
        </LinearLayout>

        <!-- Kanan: 2. Ikon Status / Kategori berdampingan dengan Thumbnail Foto Bukti -->
        <LinearLayout
            android:layout_width="80dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">

            <!-- 2. Ikon Status / Kategori -->
            <ImageView
                android:id="@+id/imgIkonStatus"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:contentDescription="Ikon Status"
                android:src="@android:drawable/stat_sys_warning"
                app:tint="#C29302"
                android:layout_marginBottom="12dp"/>

            <!-- Thumbnail Foto Bukti Mini (Dibuat melengkung lebih serasi) -->
            <androidx.cardview.widget.CardView
                android:layout_width="72dp"
                android:layout_height="54dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp">

                <ImageView
                    android:id="@+id/imgBuktiLaporan"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:contentDescription="Bukti Foto"
                    android:src="@drawable/kamera" />
            </androidx.cardview.widget.CardView>
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>